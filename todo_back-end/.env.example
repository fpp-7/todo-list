JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRATION_MINUTES=15
REFRESH_TOKEN_EXPIRATION_DAYS=7
PASSWORD_RESET_EXPIRATION_MINUTES=30
APP_FRONTEND_URL=http://localhost:4200
APP_MAIL_FROM=no-reply@todo.local
SECURE_COOKIES=false
COOKIE_SAME_SITE=Lax
PROFILE_PHOTO_MAX_BYTES=2097152
APP_LOG_DIR=.logs
ROOT_LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO
SQL_LOG_LEVEL=WARN

# Optional SMTP configuration for real password reset e-mails.
# Spring Boot reads these environment names automatically.
# SPRING_MAIL_HOST=smtp.example.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your-user
# SPRING_MAIL_PASSWORD=your-password
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
# SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
